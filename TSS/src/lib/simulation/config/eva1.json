{
  "component_name": "eva1",
  "fields": {
    "primary_battery_level": {
      "type": "float",
      "algorithm": "linear_decay",
      "min_value": 0.0,
      "max_value": 100.0,
      "rate": 0.05,
      "start_value": 100.0
      
    },
    "secondary_battery_level": {
      "type": "float",
      "algorithm": "linear_decay",
      "min_value": 0.0,
      "max_value": 100.0,
      "rate": 0.05,
      "start_value": 100.0
    },
    "oxy_pri_storage": {
      "type": "float",
      "algorithm": "linear_decay",
      "min_value": 0.0,
      "max_value": 100.0,
      "rate": 0.1,
      "start_value": 100.0
    },
    "oxy_sec_storage": {
      "type": "float",
      "algorithm": "linear_decay",
      "min_value": 0.0,
      "max_value": 100.0,
      "rate": 0.1,
      "start_value": 100.0
    },
    "oxy_pri_pressure": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "oxy_pri_storage * 30.0",
      "depends_on": ["oxy_pri_storage"]
    },
    "oxy_sec_pressure": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "oxy_sec_storage * 30.0",
      "depends_on": ["oxy_sec_storage"]
    },
    "heart_rate": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "120.0 + ( temperature - 0.0 ) * 1.55",
      "depends_on": ["temperature"]
    },
    "oxy_consumption": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "0.08 + ( heart_rate - 70.0 ) * 0.0008",
      "depends_on": ["heart_rate"]
    },
    "co2_production": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "0.08 + ( heart_rate - 70.0 ) * 0.0008",
      "depends_on": ["heart_rate"]
    },
    "suit_pressure_oxy": {
      "type": "float",
      "algorithm": "constant_value",
      "start_value": 4.0,
      "min_value": 3.0,
      "max_value": 4.0,
      "rate": 0.1

    },
    "suit_pressure_co2": {
      "type": "float",
      "algorithm": "linear_growth",
      "min_value": 0.0,
      "max_value": 0.2,
      "start_value": 0.0,
      "rate": 0.001
    },
    "suit_pressure_other": {
      "type": "float",
      "algorithm": "constant_value",
      "min_value": 0.0,
      "max_value": 0.1,
      "start_value": 0.0
    },
    "suit_pressure_total": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "suit_pressure_oxy + suit_pressure_co2 + suit_pressure_other",
      "depends_on": [
        "suit_pressure_oxy",
        "suit_pressure_co2",
        "suit_pressure_other"
      ]
    },
    "fan_pri_rpm": {
      "type": "float",
      "algorithm": "constant_value",
      "start_value": 30000.0,
      "min_value": 0.0,
      "max_value": 30500.0,
      "rate": 13574.0
    },
    "fan_sec_rpm": {
      "type": "float",
      "algorithm": "constant_value",
      "start_value": 30000.0,
      "min_value": 0.0,
      "max_value": 30500.0,
      "rate": 10.0
    },
    "helmet_pressure_co2": {
      "type": "float",
      "algorithm": "dependent_value",
      "min_value": 0.0,
      "formula": "suit_pressure_co2 * 1.5",
      "depends_on": ["suit_pressure_co2"]
    },
    "scrubber_a_co2_storage": {
      "type": "float",
      "algorithm": "linear_growth",
      "min_value": 0.0,
      "max_value": 100.0,
      "start_value": 0.0,
      "rate": 0.13
    },
    "scrubber_b_co2_storage": {
      "type": "float",
      "algorithm": "linear_growth",
      "min_value": 0.0,
      "max_value": 100.0,
      "start_value": 0.0,
      "rate": 0.13
    },
    "temperature": {
      "type": "float",
      "algorithm": "sine_wave",
      "base_value": 21.1,
      "amplitude": 5.1,
      "frequency": 0.018,
      "min_value": -10.0,
      "max_value": 40.0
    },
    "coolant_storage": {
      "type": "float",
      "algorithm": "linear_decay",
      "min_value": 0.0,
      "max_value": 100.0,
      "start_value": 100.0,
      "rate": 0.05
    },
    "coolant_gas_pressure": {
      "type": "float",
      "algorithm": "dependent_value",
      "formula": "0.0",
      "depends_on": []
    },
    "coolant_liquid_pressure": {
      "type": "float",
      "algorithm": "sine_wave",
      "base_value": 500,
      "amplitude": 2,
      "frequency": 0.015,
      "min_value": 480.0,
      "max_value": 520.0

    },
    "eva_elapsed_time": {
      "type": "float",
      "algorithm": "linear_growth",
      "min_value": 0.0,
      "max_value": 10000.0,
      "start_value": 0.0,
      "rate": 1.0
    }
  }
}
