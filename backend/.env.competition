# Competition-day AIA settings (Ollama + agentic mode).
#
# Activate on the AIA laptop before start:
#   cp backend/.env.competition backend/.env
#   ./scripts/aia-start.sh <JAVA_HUB_IP>
#
# Prerequisites on this machine:
#   - Ollama running locally (ollama pull llama3.2)
#   - curl http://127.0.0.1:11434/api/tags  →  lists llama3.2
#
# JAVA_HUB_IP is written by aia-start.sh; placeholder below is overwritten.
# Fallback (no Ollama): cp backend/.env.example backend/.env  (agentic off)

EVA_JAVA_BACKEND_URL=http://127.0.0.1:7070
EVA_LIVE_TELEMETRY=true
EVA_DEMO_MODE=false
EVA_AGENTIC_ENABLED=true
EVA_ASR_ENABLED=true
EVA_OLLAMA_BASE_URL=http://127.0.0.1:11434
EVA_OLLAMA_MODEL=llama3.2
EVA_JAVA_HTTP_TIMEOUT_S=3
EVA_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
