# Copy to backend/.env and set JAVA host IP for competition day.
# cp backend/.env.example backend/.env
#
# Start / stop (from repo root):
#   ./scripts/aia-start.sh        # exits immediately if config or Hub is bad
#   ./scripts/aia-stop.sh

EVA_JAVA_BACKEND_URL=http://192.168.1.20:7070
EVA_LIVE_TELEMETRY=true
EVA_DEMO_MODE=true
EVA_AGENTIC_ENABLED=false
EVA_ASR_ENABLED=true
EVA_JAVA_HTTP_TIMEOUT_S=3
EVA_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
