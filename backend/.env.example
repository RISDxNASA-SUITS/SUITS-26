# Copy once: cp backend/.env.example backend/.env
# Java Hub IP is set each time you run: ./scripts/aia-start.sh
#
# Competition (Ollama + agentic): cp backend/.env.competition backend/.env
#
# Stop AIA: ./scripts/aia-stop.sh

EVA_JAVA_BACKEND_URL=http://127.0.0.1:7070
EVA_LIVE_TELEMETRY=true
EVA_DEMO_MODE=true
EVA_AGENTIC_ENABLED=false
EVA_ASR_ENABLED=true
EVA_JAVA_HTTP_TIMEOUT_S=3
EVA_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
